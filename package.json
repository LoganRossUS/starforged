{
  "name": "starforged-companion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An unofficial, client-side companion app for playing Ironsworn: Starforged.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "build:content": "node scripts/build-content.mjs",
    "copy:assets": "node scripts/copy-assets.mjs",
    "prepare:content": "npm run build:content && npm run copy:assets",
    "postinstall": "npm run prepare:content"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@datasworn/starforged": "^0.0.10",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
